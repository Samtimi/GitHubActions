      "APItest": "npx playwright test --grep @API",
      "runtestinparallel": "npx playwright test --project=chromium --workers=3",
      "testgenerateallurereport": "npx playwright test tests/rahul/ClientApp.spec.js --project=chromium && allure generate ./allure-report --clean -o allure-report && allure open allure-report",
      "testallurereport": "allure generate my-allure-results --clean -o allure-report && allure open allure-report"


